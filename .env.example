# ─────────────────────────────────────────────
# Copy this file to .env and fill in all values
# NEVER commit the real .env to version control
# ─────────────────────────────────────────────

# ── Server ────────────────────────────────────
PORT=5001
NODE_ENV=production

# ── Database ──────────────────────────────────
DB_HOST=mysql           # Docker service name — do NOT change
DB_PORT=3306
DB_USER=billsplit
DB_PASSWORD=change_me_strong_password
