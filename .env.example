# ─────────────────────────────────────────────
# Copy this file to .env and fill in all values
# NEVER commit the real .env to version control
# ─────────────────────────────────────────────

# ── Server ────────────────────────────────────
PORT=5001
NODE_ENV=production

# ── Database ──────────────────────────────────
DB_HOST=mysql           # Docker service name — do NOT change
DB_PORT=3306
DB_USER=billsplit
DB_PASSWORD=change_me_strong_password
DB_NAME=billsplit_db

# ── Amazon Cognito ────────────────────────────
COGNITO_USER_POOL_ID=us-west-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=us-west-1

# ── Amazon SES (SMTP) ─────────────────────────
SES_SMTP_HOST=email-smtp.us-west-1.amazonaws.com
SES_SMTP_PORT=587
SES_SMTP_USER=your_ses_smtp_username
SES_SMTP_PASSWORD=your_ses_smtp_password
SES_FROM_EMAIL=noreply@yourdomain.com
SES_FROM_NAME=BillSplit App

# ── Stripe ───────────────────────────────────
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_PLUS_MONTHLY_PRICE_ID=price_xxx
STRIPE_PLUS_YEARLY_PRICE_ID=price_xxx
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx
STRIPE_PRO_YEARLY_PRICE_ID=price_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── App ───────────────────────────────────────
# Set to your Amplify frontend URL after deployment
FRONTEND_URL=https://app.yourdomain.com
APP_NAME=SpendSync
